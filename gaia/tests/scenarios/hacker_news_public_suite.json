{
  "suite_id": "hacker_news_public_v2",
  "site": {
    "name": "Hacker News",
    "base_url": "https://news.ycombinator.com/",
    "mode": "public_readonly"
  },
  "grader_configs": {
    "reason_codes": {
      "forbidden_reason_codes": [
        "user_intervention_missing"
      ]
    }
  },
  "scenarios": [
    {
      "id": "HN_001_TOP_STORIES",
      "name": "기술 뉴스 목록 확인",
      "url": "https://news.ycombinator.com/",
      "goal": "Hacker News 첫 화면에서 이야기 제목 목록, 점수, 사용자 링크 중 두 가지를 확인해줘.",
      "constraints": {
        "allow_navigation": true,
        "require_ref_only": true,
        "require_state_change": false
      },
      "expected_signals": [],
      "time_budget_sec": 600
    },
    {
      "id": "HN_002_NEWEST_LIST",
      "name": "최신 목록 확인",
      "url": "https://news.ycombinator.com/newest",
