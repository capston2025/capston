{
  "suite_id": "hacker_news_public_v1",
  "site": {
    "name": "Hacker News",
    "base_url": "https://news.ycombinator.com/",
    "mode": "public_readonly"
  },
  "grader_configs": {
    "reason_codes": {
      "forbidden_reason_codes": [
        "user_intervention_missing"
      ]
    }
  },
  "scenarios": [
    {
      "id": "HN_001_HOME_LANDMARK",
      "name": "홈/핵심 랜드마크 확인",
      "url": "https://news.ycombinator.com/",
      "goal": "Hacker News 공개 홈 화면에서 검색창, 주요 메뉴, 핵심 콘텐츠 영역 중 최소 두 가지가 보이는지 확인해줘.",
      "constraints": {
        "allow_navigation": true,
        "require_ref_only": true,
        "require_state_change": false
      },
      "expected_signals": [],
      "time_budget_sec": 600
    },
    {
      "id": "HN_002_SEARCH_OR_NAVIGATION",
      "name": "검색 또는 주요 내비게이션",
      "url": "https://news.ycombinator.com/",
      "goal": "Hacker News에서 new 또는 past 링크 관련 공개 검색이나 주요 내비게이션을 수행하고 결과 목록 또는 이동한 화면이 보이는지 확인해줘.",
      "constraints": {
        "allow_navigation": true,
        "require_ref_only": true,
        "require_state_change": false
      },
      "expected_signals": [],
      "time_budget_sec": 600
    },
    {
      "id": "HN_003_DETAIL_ENTRY",
