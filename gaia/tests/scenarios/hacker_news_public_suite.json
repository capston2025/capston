      "constraints": {
        "allow_navigation": true,
        "require_ref_only": true,
        "require_state_change": false
      },
      "expected_signals": [],
      "time_budget_sec": 600
    },
    {
      "id": "HN_003_ITEM_DISCUSSION",
      "name": "이야기 상세 확인",
