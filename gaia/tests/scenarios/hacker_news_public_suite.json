      "url": "https://news.ycombinator.com/",
      "goal": "Hacker News에서 첫 화면의 공개 글 상세 또는 comments 페이지로 진입해 제목, 이미지, 본문, 표 중 확인 가능한 상세 정보가 보이는지 확인해줘.",
      "constraints": {
        "allow_navigation": true,
        "require_ref_only": true,
        "require_state_change": false
      },
      "expected_signals": [],
      "time_budget_sec": 600
