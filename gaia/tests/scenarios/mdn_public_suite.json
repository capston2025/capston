{
  "suite_id": "mdn_public_v1",
  "site": {
    "name": "MDN Web Docs Korea",
    "base_url": "https://developer.mozilla.org/ko/",
    "mode": "public_readonly"
  },
  "grader_configs": {
    "reason_codes": {
      "forbidden_reason_codes": [
        "user_intervention_missing"
      ]
    }
  },
  "scenarios": [
    {
      "id": "MDN_001_HOME_DOCS_READY",
      "url": "https://developer.mozilla.org/ko/",
      "goal": "MDN 홈에서 검색 버튼과 주요 문서 카테고리 링크가 이미 보이는지 확인하고 종료해줘.",
      "constraints": {
        "allow_navigation": false,
        "require_ref_only": true,
        "require_state_change": false
      },
      "expected_signals": [
        "heading_visible",
        "search_button_visible",
        "link_visible"
      ],
      "difficulty": "easy",
      "time_budget_sec": 60
    },
    {
      "id": "MDN_002_OPEN_CSS_DOCS",
      "url": "https://developer.mozilla.org/ko/",
      "goal": "홈에서 CSS 링크를 따라 CSS 문서 페이지를 열고 제목과 본문이 보이는지 확인해줘.",
      "constraints": {
        "allow_navigation": true,
        "require_ref_only": true,
        "require_state_change": true
      },
      "expected_signals": [
        "url_change",
        "heading_visible",
        "content_visible"
      ],
      "difficulty": "medium",
      "time_budget_sec": 120
    },
    {
      "id": "MDN_003_SEARCH_AND_OPEN_JAVASCRIPT",
      "url": "https://developer.mozilla.org/ko/",
      "goal": "검색 기능으로 JavaScript 관련 문서를 찾아 열고 문서 제목이 보이는지 확인해줘.",
      "constraints": {
        "allow_navigation": true,
        "require_ref_only": true,
        "require_state_change": true
      },
      "expected_signals": [
        "search_results_changed",
        "url_change",
        "heading_visible"
      ],
      "difficulty": "medium",
      "time_budget_sec": 150
    }
  ]
}
