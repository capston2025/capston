{
  "suite_id": "inuu_login_smoke_pr",
  "site": {
    "name": "INU Timetable",
    "base_url": "https://inuu-timetable.vercel.app/",
    "mode": "service_e2e"
  },
  "grader_configs": {
    "reason_codes": {
      "forbidden_reason_codes": [
        "user_intervention_missing"
      ]
    }
  },
  "scenarios": [
    {
      "id": "INUU_006_LOGIN_AND_ADD_WISHLIST",
      "url": "https://inuu-timetable.vercel.app/",
      "goal": "로그인 후 과목 하나를 위시리스트에 담고 위시리스트 수치가 증가했는지 확인해줘.",
      "constraints": {
        "allow_navigation": true,
        "require_ref_only": true,
        "require_state_change": true,
        "requires_test_credentials": true
      },
      "expected_signals": [
        "auth_completed",
        "wishlist_count_increased"
      ],
      "grader_configs": {
        "membership": {
          "expected_present": true,
          "destination_terms": [
            "위시리스트"
          ]
        },
        "blocked_vs_fail": {
          "allowed_blocked_statuses": [
            "blocked_user_action"
          ],
          "allowed_blocked_markers": [
            "사용자 개입",
            "captcha",
            "로그인"
          ],
          "forbidden_fail_markers": [
            "timeout",
            "exception",
            "request_exception",
            "dom_snapshot_retry_exhausted"
          ]
        }
      },
      "difficulty": "hard",
      "time_budget_sec": 180
    },
    {
      "id": "INUU_007_LOGIN_AND_REMOVE_WISHLIST",
      "url": "https://inuu-timetable.vercel.app/",
      "goal": "로그인 후 위시리스트에 담긴 과목 하나를 제거하고 위시리스트 수치가 감소했는지 확인해줘.",
      "constraints": {
        "allow_navigation": true,
        "require_ref_only": true,
        "require_state_change": true,
        "requires_test_credentials": true
      },
      "expected_signals": [
        "auth_completed",
        "wishlist_count_decreased"
      ],
      "grader_configs": {
        "membership": {
          "expected_present": false,
          "destination_terms": [
            "위시리스트"
          ]
        },
        "blocked_vs_fail": {
          "allowed_blocked_statuses": [
            "blocked_user_action"
          ],
          "allowed_blocked_markers": [
            "사용자 개입",
            "captcha",
            "로그인"
          ],
          "forbidden_fail_markers": [
            "timeout",
            "exception",
            "request_exception",
            "dom_snapshot_retry_exhausted"
          ]
        }
      },
      "difficulty": "hard",
      "time_budget_sec": 180
    }
  ]
}