{
  "suite_id": "inuu_public_smoke_pr",
  "site": {
    "name": "INU Timetable",
    "base_url": "https://inuu-timetable.vercel.app/",
    "mode": "service_e2e"
  },
  "grader_configs": {
    "reason_codes": {
      "forbidden_reason_codes": [
        "user_intervention_missing"
      ]
    }
  },
  "scenarios": [
    {
      "id": "INUU_001_HOME_LOGIN_VISIBLE",
      "url": "https://inuu-timetable.vercel.app/",
      "goal": "현재 메인 화면에서 로그인 버튼 또는 로그아웃 버튼 중 하나가 이미 보이는지 확인하고 추가 조작 없이 종료해줘.",
      "constraints": {
        "allow_navigation": false,
        "require_ref_only": true,
        "require_state_change": false
      },
      "expected_signals": [
        "text_visible",
        "cta_visible"
      ],
      "difficulty": "easy",
      "time_budget_sec": 45
    },
    {
      "id": "INUU_002_SEARCH_CHANGES_RESULTS",
      "url": "https://inuu-timetable.vercel.app/",
      "goal": "과목 검색창에 키워드를 입력해 검색 결과 목록이 실제로 바뀌는지 검증해줘.",
      "constraints": {
        "allow_navigation": false,
        "require_ref_only": true,
        "require_state_change": true
      },
      "expected_signals": [
        "target_value_changed",
        "dom_changed"
      ],
      "difficulty": "easy",
      "time_budget_sec": 90
    },
    {
      "id": "INUU_003_CREDIT_FILTER_SEMANTIC",
      "url": "https://inuu-timetable.vercel.app/",
      "goal": "학점 필터가 실제 결과 과목의 학점과 맞게 동작하는지 의미 검증해줘.",
      "constraints": {
        "allow_navigation": true,
        "require_ref_only": true,
        "require_state_change": true
      },
      "expected_signals": [
        "selection_reflected",
        "result_consistency"
      ],
      "difficulty": "medium",
      "time_budget_sec": 120
    },
    {
      "id": "INUU_004_DIVISION_FILTER",
      "url": "https://inuu-timetable.vercel.app/",
      "goal": "구분 또는 전공/교양 관련 필터를 바꿨을 때 결과 목록이 실제로 바뀌는지 검증해줘.",
      "constraints": {
        "allow_navigation": false,
        "require_ref_only": true,
        "require_state_change": true
      },
      "expected_signals": [
        "target_value_changed",
        "dom_changed"
      ],
      "difficulty": "medium",
      "time_budget_sec": 90
    },
    {
      "id": "INUU_005_PAGINATION_PERSISTS",
      "url": "https://inuu-timetable.vercel.app/",
      "goal": "과목 목록 페이지네이션을 한 번 넘긴 뒤에도 필터나 검색 상태가 유지되는지 확인해줘.",
      "constraints": {
        "allow_navigation": true,
        "require_ref_only": true,
        "require_state_change": true
      },
      "expected_signals": [
        "pagination_advanced",
        "persistence_evaluated"
      ],
      "difficulty": "medium",
      "time_budget_sec": 120
    }
  ]
}
