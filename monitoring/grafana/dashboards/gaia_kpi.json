          "instant": true,
          "refId": "A"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "gaia-prometheus"
          },
          "expr": "max by (runner_id, site_key, site, category, volatility) (gaia_external_site_runs_total{model=~\"$model\",runner_id=~\"$runner_id\"})",
          "instant": true,
          "refId": "B"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "gaia-prometheus"
          },
          "expr": "max by (runner_id, site_key, site, category, volatility) (gaia_external_site_avg_duration_seconds{model=~\"$model\",runner_id=~\"$runner_id\"})",
          "instant": true,
          "refId": "C"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "gaia-prometheus"
          },
          "expr": "max by (runner_id, site_key, site, category, volatility) (gaia_external_site_blocked_count{model=~\"$model\",runner_id=~\"$runner_id\"})",
          "instant": true,
          "refId": "D"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "gaia-prometheus"
          },
          "expr": "max by (runner_id, site_key, site, category, volatility) (gaia_external_site_latest_status{model=~\"$model\",runner_id=~\"$runner_id\"})",
          "instant": true,
          "refId": "E"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "auto",
            "displayMode": "auto",
            "wrap": true
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "SUCCESS RATE"
            },
            "properties": [
              {
                "id": "unit",
                "value": "percentunit"
              },
              {
                "id": "custom.displayMode",
                "value": "color-background"
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "PRIMARY RATE"
            },
            "properties": [
              {
                "id": "unit",
                "value": "percentunit"
              },
              {
                "id": "custom.displayMode",
                "value": "color-background"
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "AVG SEC"
            },
            "properties": [
              {
                "id": "unit",
                "value": "s"
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "LATEST"
            },
            "properties": [
              {
                "id": "custom.displayMode",
                "value": "color-background"
              },
              {
                "id": "mappings",
                "value": [
                  {
                    "type": "value",
                    "options": {
                      "1": {
                        "text": "SUCCESS",
                        "color": "green"
                      },
                      "0": {
                        "text": "FAIL",
                        "color": "red"
                      }
                    }
                  }
                ]
              }
            ]
          }
        ]
      },
      "options": {
        "sortBy": [
          {
            "displayName": "SUCCESS RATE",
            "desc": false
          }
        ]
      },
      "transformations": [
        {
          "id": "labelsToFields",
          "options": {
            "mode": "columns"
          }
        },
        {
          "id": "merge",
          "options": {}
        },
        {
          "id": "filterFieldsByName",
          "options": {
            "include": {
              "names": [
                "site_key",
                "site",
                "runner_id",
                "category",
                "volatility",
                "gaia_external_site_success_rate",
                "gaia_external_site_runs_total",
                "gaia_external_site_avg_duration_seconds",
                "gaia_external_site_blocked_count",
                "gaia_external_site_latest_status"
              ]
            }
          }
        },
        {
          "id": "organize",
          "options": {
            "renameByName": {
              "site_key": "SITE KEY",
              "site": "SITE",
              "runner_id": "RUNNER",
              "category": "CATEGORY",
              "volatility": "VOLATILITY",
              "gaia_external_site_success_rate": "SUCCESS RATE",
              "gaia_external_site_runs_total": "RUNS",
              "gaia_external_site_avg_duration_seconds": "AVG SEC",
              "gaia_external_site_blocked_count": "BLOCKED",
              "gaia_external_site_latest_status": "LATEST"
            },
            "indexByName": {
              "site_key": 0,
              "site": 1,
              "runner_id": 2,
              "category": 3,
              "volatility": 4,
              "gaia_external_site_success_rate": 5,
              "gaia_external_site_runs_total": 6,
              "gaia_external_site_avg_duration_seconds": 7,
              "gaia_external_site_blocked_count": 8,
              "gaia_external_site_latest_status": 9
            },
            "excludeByName": {
              "Time": true
            }
          }
        }
      ]
    },
