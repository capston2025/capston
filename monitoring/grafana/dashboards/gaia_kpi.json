{
  "title": "GAIA Benchmark Results",
  "uid": "gaia-kpi-v1",
  "schemaVersion": 38,
  "version": 3,
  "refresh": "30s",
  "time": {
    "from": "now-7d",
    "to": "now"
  },
  "timezone": "browser",
  "tags": [
    "gaia",
    "benchmark"
  ],
  "templating": {
    "list": [
      {
        "name": "suite_id",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "gaia-prometheus"
        },
        "query": {
          "query": "label_values(gaia_scenario_runs_total{suite_id=~\".*_public_v2$\"}, suite_id)",
          "refId": "A"
        },
        "refresh": 2,
        "sort": 1,
        "multi": false,
        "includeAll": false,
        "label": "Suite"
      },
      {
        "name": "scenario_id",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "gaia-prometheus"
        },
        "query": {
          "query": "label_values(gaia_scenario_runs_total{suite_id=\"$suite_id\"}, scenario_id)",
          "refId": "A"
        },
        "refresh": 2,
        "sort": 1,
        "multi": false,
        "includeAll": true,
        "allValue": ".*",
        "label": "Scenario"
      },
      {
        "name": "model",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "gaia-prometheus"
        },
        "query": {
          "query": "label_values({__name__=~\"gaia_scenario_runs_total|gaia_external_pack_success_rate\"}, model)",
          "refId": "A"
        },
        "refresh": 2,
        "multi": true,
        "includeAll": true,
        "allValue": ".*",
        "label": "Model"
      },
      {
        "name": "runner_id",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "gaia-prometheus"
        },
        "query": {
          "query": "label_values({__name__=~\"gaia_scenario_runs_total|gaia_external_pack_success_rate\"}, runner_id)",
          "refId": "A"
        },
        "refresh": 2,
        "multi": true,
        "includeAll": true,
        "allValue": ".*",
        "label": "Runner"
      }
    ]
  },
  "panels": [
