    {
      "id": 21,
      "title": "라운드별 결과",
      "type": "ae3e-plotly-panel",
      "gridPos": { "x": 0, "y": 18, "w": 24, "h": 16 },
      "fieldConfig": { "defaults": {}, "overrides": [] },
      "options": {
        "script": "var rounds = {};\n\ndata.series.forEach(function(frame) {\n  var refId = frame.refId || '';\n  var round = null;\n  var scenario_id = null;\n  var winner = null;\n  var value = null;\n\n  frame.fields.forEach(function(field) {\n    if (field.labels) {\n      if (field.labels.round) round = field.labels.round;\n      if (field.labels.scenario_id) scenario_id = field.labels.scenario_id;\n      if (field.labels.winner) winner = field.labels.winner;\n    }\n    if (field.type === 'number' && field.values && field.values.length > 0) {\n      value = field.values[field.values.length - 1];\n    }\n  });\n\n  if (!round || !scenario_id) return;\n\n  if (!rounds[round]) {\n    rounds[round] = { round: parseInt(round), scenario_id: scenario_id };\n  }\n\n  if (refId === 'A') {\n    rounds[round].human_time = value;\n  } else if (refId === 'B') {\n    rounds[round].gaia_time = value;\n  } else if (refId === 'C') {\n    rounds[round].human_ok = value === 1;\n  } else if (refId === 'D') {\n    rounds[round].gaia_ok = value === 1;\n  } else if (refId === 'E') {\n    rounds[round].speed_ratio = value;\n  } else if (refId === 'F' && winner && value === 1) {\n    rounds[round].winner = winner;\n  }\n});\n\nvar rows = Object.values(rounds).sort(function(a, b) { return a.round - b.round; });\n\nif (rows.length === 0) {\n  return {\n    data: [{ type: 'table',\n      header: { values: [['라운드'], ['시나리오'], ['👤 체험자'], ['🤖 GAIA'], ['⚡ 배속'], ['승자']],\n        fill: { color: '#1a1a2e' }, font: { color: '#aaaacc', size: 13 }, align: 'center' },\n      cells: { values: [['—'], ['아직 기록 없음'], ['—'], ['—'], ['—'], ['—']],\n        fill: { color: '#1e1e3a' }, font: { color: '#888899', size: 12 }, align: 'center', height: 36 }\n    }],\n    layout: { paper_bgcolor: 'rgba(0,0,0,0)', plot_bgcolor: 'rgba(0,0,0,0)',\n      font: { color: '#ffffff' }, margin: { t: 10, b: 10, l: 10, r: 10 } },\n    config: { responsive: true }\n  };\n}\n\nvar colRound     = rows.map(function(r) { return 'R' + r.round; });\nvar colScenario  = rows.map(function(r) { return r.scenario_id; });\nvar colHuman     = rows.map(function(r) {\n  if (r.human_time == null) return '?';\n  return Math.round(r.human_time) + '초 ' + (r.human_ok ? '✅' : '❌');\n});\nvar colGaia      = rows.map(function(r) {\n  if (r.gaia_time == null) return '?';\n  return r.gaia_time.toFixed(1) + '초 ' + (r.gaia_ok ? '✅' : '❌');\n});\nvar colRatio     = rows.map(function(r) {\n  if (!r.speed_ratio) return '—';\n  return r.speed_ratio.toFixed(1) + '×';\n});\nvar colWinner    = rows.map(function(r) {\n  var m = { gaia: '🤖 GAIA', human: '👤 체험자', draw: '🤝 무승부', unknown: '—' };\n  return m[r.winner] || '—';\n});\n\nvar winnerBg = rows.map(function(r) {\n  if (r.winner === 'gaia')  return 'rgba(26,92,42,0.8)';\n  if (r.winner === 'human') return 'rgba(26,58,92,0.8)';\n  if (r.winner === 'draw')  return 'rgba(60,60,60,0.8)';\n  return 'rgba(30,30,58,0.4)';\n});\n\nvar nRows = rows.length;\nvar cellBg = [\n  Array(nRows).fill('rgba(30,30,58,0.6)'),\n  Array(nRows).fill('rgba(30,30,58,0.6)'),\n  Array(nRows).fill('rgba(30,30,58,0.6)'),\n  Array(nRows).fill('rgba(30,30,58,0.6)'),\n  Array(nRows).fill('rgba(30,30,58,0.6)'),\n  winnerBg\n];\n\nreturn {\n  data: [{\n    type: 'table',\n    header: {\n      values: [['라운드'], ['시나리오'], ['👤 체험자'], ['🤖 GAIA'], ['⚡ 배속'], ['승자']],\n      fill: { color: '#1a1a2e' },\n      font: { color: '#aaaacc', size: 14 },\n      align: ['center', 'left', 'center', 'center', 'center', 'center'],\n      line: { width: 1, color: '#333355' },\n      height: 40\n    },\n    cells: {\n      values: [colRound, colScenario, colHuman, colGaia, colRatio, colWinner],\n      fill: { color: cellBg },\n      font: { color: '#ffffff', size: 13 },\n      align: ['center', 'left', 'center', 'center', 'center', 'center'],\n      line: { width: 1, color: '#2a2a4a' },\n      height: 36\n    }\n  }],\n  layout: {\n    paper_bgcolor: 'rgba(0,0,0,0)',\n    plot_bgcolor: 'rgba(0,0,0,0)',\n    font: { color: '#ffffff', family: 'Arial', size: 13 },\n    margin: { t: 10, b: 10, l: 10, r: 10 }\n  },\n  config: { responsive: true }\n};",
        "onclick": "",
        "jsonData": ""
      },
